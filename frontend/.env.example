# -----------------------------------------------------------------------------
# Spectra frontend — split deploy (static host + separate API)
# Vite injects these at *build* time. Rebuild after changing values for prod.
# -----------------------------------------------------------------------------

# --- Local development -------------------------------------------------------
# Option A — point REST at FastAPI directly:
VITE_API_BASE_URL=http://localhost:8000
# Option B — omit VITE_API_BASE_URL and rely on Vite proxy (vite.config) → http://127.0.0.1:8000

# WebSocket always hits the API host (no proxy). Local:
VITE_WS_URL=ws://localhost:8000/ws/vehicle

# Optional alias for VITE_API_BASE_URL (useful when you only add one “API URL” in a host’s UI).
# VITE_API_URL=https://your-api.example.com

# --- Production: Vercel + Render (recommended) -------------------------------
# Do NOT set VITE_API_BASE_URL on Vercel. REST uses same-origin /api/*; vercel.json rewrites
# proxy to Render (avoids CORS + many ad blockers that block onrender.com fetches).
# DO set WebSocket explicitly (cannot be proxied by static rewrites):
# VITE_WS_URL=wss://your-service.onrender.com/ws/vehicle
#
# Remove CORS_ORIGINS from Vercel — it only belongs on Render (backend).
#
# --- Production: direct API URL (alternative) --------------------------------
# If you skip rewrites and call Render from the browser, set BOTH and fix CORS on Render:
# VITE_API_BASE_URL=https://your-service.onrender.com
# VITE_WS_URL=wss://your-service.onrender.com/ws/vehicle
#
# Notes:
# - Browsers require wss:// when the page is served over https://.
# - If the WebSocket is not at /ws/vehicle on the same host as REST, set VITE_WS_URL explicitly.
# - Reverse proxies (Cloudflare, ALB, nginx) must allow WebSocket upgrade
#   (Connection: Upgrade, Upgrade: websocket); otherwise WS will fail while REST may work.
