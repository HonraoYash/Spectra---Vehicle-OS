# -----------------------------------------------------------------------------
# Spectra frontend — split deploy (static host + separate API)
# Vite injects these at *build* time. Rebuild after changing values for prod.
# -----------------------------------------------------------------------------

# --- Local development -------------------------------------------------------
# REST base (no trailing slash). Must match the FastAPI origin.
VITE_API_BASE_URL=http://localhost:8000

# Full WebSocket URL including path. Must hit the same logical API host as REST
# unless you intentionally terminate WS elsewhere (document that separately).
VITE_WS_URL=ws://localhost:8000/ws/vehicle

# --- Production (copy/adjust for your hosts) ---------------------------------
# Use https + wss in production. Example:
# VITE_API_BASE_URL=https://api.example.com
# VITE_WS_URL=wss://api.example.com/ws/vehicle
#
# Notes:
# - Browsers require wss:// when the page is served over https://.
# - If API path prefix and WS path live on different hosts, set both vars explicitly
#   (do not assume one can be derived from the other).
# - Reverse proxies (Cloudflare, ALB, nginx) must allow WebSocket upgrade
#   (Connection: Upgrade, Upgrade: websocket); otherwise WS will fail while REST may work.
